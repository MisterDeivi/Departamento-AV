---
export interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
---

<article class={`relative overflow-hidden card-elevated p-6 sm:p-8 group flex flex-col justify-between ${className}`}>
  <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent pointer-events-none"></div>
  <div class="relative z-10 w-full h-full flex flex-col">
    <slot />
  </div>
</article>
