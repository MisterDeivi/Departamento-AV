---
export interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="mb-10 sm:mb-14 relative z-10 max-w-3xl">
  {eyebrow && <p class="mb-3 text-[11px] sm:text-xs font-bold uppercase tracking-[0.2em] text-[color:var(--brand-green)] flex items-center gap-2"><span class="w-3 h-[1px] bg-[color:var(--brand-green)]"></span>{eyebrow}</p>}
  <h2 class="text-3xl font-extrabold text-[color:var(--brand-gray)] sm:text-4xl md:text-5xl tracking-tight leading-[1.15]">{title}</h2>
  {description && <p class="mt-4 text-base text-[color:var(--text-soft)] sm:text-lg leading-relaxed">{description}</p>}
</header>
