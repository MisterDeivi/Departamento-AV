---
import Card from '@/components/ui/Card.astro';
import Badge from '@/components/ui/Badge.astro';
import type { OrganigramaNode } from '@/lib/types';

export interface Props {
  node: OrganigramaNode;
}

const { node } = Astro.props;
---

<Card>
  <div class="mb-3 flex items-start justify-between gap-3">
    <h3 class="text-base font-semibold text-[color:var(--brand-gray)] sm:text-lg">{node.titulo}</h3>
    <Badge label={node.area} />
  </div>
  <p class="text-sm text-[color:var(--brand-gray)]">{node.responsable}</p>
  <p class="mt-2 text-sm text-[color:var(--text-soft)]">{node.descripcion}</p>
</Card>
