---
import Container from '@/components/ui/Container.astro';
import Card from '@/components/ui/Card.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';

const areas = [
  {
    title: 'Grupo Audio',
    text: 'Se encarga de instalar y configurar todo el sistema de audio, altavoces, cableado de sonido y operación de mezclador durante el programa, velando por la calidad del sonido.',
    image: '/images/audio.webp', // Local audio webp
    href: '/grupos?area=Audio',
  },
  {
    title: 'Grupo Video',
    text: 'Se encarga de instalar y configurar todas las pantallas LED, además de operar hábilmente las cámaras y dispositivos de transmisión con el contenido multimedia, principalmente durante las asambleas regionales.',
    image: '/images/video.webp', // Local video webp
    href: '/grupos?area=Video',
  },
  {
    title: 'Grupo Plataforma',
    text: 'Se encarga de las tareas en plataforma, ajustar micrófonos o atriles, y flujo de salidas/entradas de oradores bajo supervisión del departamento.',
    image: 'https://images.unsplash.com/photo-1478737270239-2f02b77fc618?q=80&w=1200&auto=format&fit=crop', // Podium mic high quality
    href: '/grupos?area=Plataforma',
  }
];
---

<section class="py-12 sm:py-16 md:py-24 relative">
  <Container>
    <SectionHeader
      eyebrow="Estructura operativa"
      title="Nuestros equipos"
      description="El departamento está cimentado en tres columnas fundamentales. Cada grupo cuenta con responsables definidos, colaborando entre sí para el éxito del programa."
    />
    <div class="grid gap-6 lg:grid-cols-3 md:grid-cols-2 mt-4">
      {areas.map((area) => (
        <a href={area.href} class="group relative flex flex-col justify-end overflow-hidden rounded-[2rem] bg-gray-900 min-h-[360px] sm:min-h-[420px] transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-[color:var(--brand-green)]/20 focus:outline-none focus:ring-4 focus:ring-[color:var(--brand-green)]">
          {/* Background Image */}
          <img src={area.image} alt={`Operador trabajando en ${area.title}`} loading="lazy" class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-80 group-hover:opacity-100" />
          
          {/* Gradient Overlays */}
          <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-black/90 via-black/50 to-transparent"></div>
          <div class="absolute inset-0 bg-gradient-to-tr from-[color:var(--brand-green)]/40 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          
          {/* Content */}
          <div class="relative z-10 p-8 sm:p-10">
            <h3 class="text-3xl font-extrabold text-white tracking-tight drop-shadow-md">
              {area.title}
            </h3>
            <p class="mt-3 text-sm font-medium text-gray-200 leading-relaxed max-w-sm drop-shadow-sm">
              {area.text}
            </p>
            <div class="mt-6 flex items-center gap-2 text-sm font-bold text-white transition-all group-hover:text-[color:var(--brand-green-soft)] group-hover:gap-3">
              Explorar distribución
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="drop-shadow-sm"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </Container>
</section>
