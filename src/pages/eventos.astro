---
import MainLayout from '@/layouts/MainLayout.astro';
import Container from '@/components/ui/Container.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import EventsTimeline from '@/components/data-display/EventsTimeline';
import EventsCalendar from '@/components/data-display/EventsCalendar';
import { eventos } from '@/data/eventos';
---

<MainLayout title="Eventos | AV Guarico 1" description="Fechas importantes del operativo AV.">
  <section class="py-10 sm:py-12">
    <Container>
      <SectionHeader
        eyebrow="Agenda tecnica"
        title="Eventos y fechas importantes"
        description="Consulta la secuencia operativa con timeline animada y vista calendario para planificacion por fecha."
      />

      <div class="grid gap-5 xl:grid-cols-[1.15fr_1fr]">
        <div class="surface-glass rounded-2xl p-4 sm:p-5">
          <p class="mb-4 text-xs font-semibold uppercase tracking-[0.08em] text-[color:var(--brand-green)]">Timeline priorizada</p>
          <EventsTimeline eventos={eventos} client:load />
        </div>

        <EventsCalendar eventos={eventos} client:load />
      </div>
    </Container>
  </section>
</MainLayout>
