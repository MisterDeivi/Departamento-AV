---
import MainLayout from '@/layouts/MainLayout.astro';
import Container from '@/components/ui/Container.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Card from '@/components/ui/Card.astro';
import Badge from '@/components/ui/Badge.astro';

const organigramas = [
  {
    titulo: 'Equipos de trabajo',
    categoria: 'General',
    descripcion: 'En este documento se muestran todos los equipos de trabajo, el área a trabajar, capitanes de equipo y voluntarios asignados (similar a nuestra vista de grupos operativos).',
    fileName: 'organigrama-equipos.pdf'
  },
  {
    titulo: 'Configuración Técnica',
    categoria: 'Superintendencia',
    descripcion: 'Muestra la supervisión general: Superintendente AV, superintendentes de Audio, Video, Plataforma y sus auxiliares. Detalla las funciones y responsables de cada área de instalación, además de la gestión de recursos empresariales (hidratación, inventario) y apoyo general.',
    fileName: 'organigrama-tecnico.pdf'
  },
  {
    titulo: 'Programa',
    categoria: 'Operación',
    descripcion: 'Enfocado en las responsabilidades exclusivas durante el programa de asamblea, como la operación del mezclador y conmutador, operador de cámara, multimedia y dirección técnica.',
    fileName: 'organigrama-programa.pdf'
  },
  {
    titulo: 'Maquilladoras',
    categoria: 'Cámaras',
    descripcion: 'Este organigrama presenta las hermanas encargadas de maquillar a los oradores, cuyo objetivo es evitar el exceso de brillo en rostro para que se vean de excelente manera en las transmisiones.',
    fileName: 'organigrama-maquilladoras.pdf'
  }
];
---

<MainLayout title="Organigramas | AV Guárico 1" description="Consulta y descarga los organigramas oficiales del departamento de Audio y Video.">
  <section class="py-12 sm:py-20 relative">
    <Container>
      <SectionHeader
        eyebrow="Estructura y Documentación"
        title="Nuestros Organigramas"
        description="Aquí podrás consultar y descargar todos los organigramas oficiales en formato PDF para conocer profundamente la estructura técnica, logística y administrativa de nuestro departamento."
      />
      
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-2 max-w-5xl mx-auto">
        {organigramas.map((org) => (
          <Card className="h-full flex flex-col group relative overflow-hidden transition-all duration-300 hover:shadow-xl hover:shadow-[color:var(--brand-green)]/10 hover:-translate-y-1">
            <div class="absolute top-0 right-0 -mr-12 -mt-12 w-24 h-24 bg-[color:var(--brand-green)] opacity-[0.03] rounded-full blur-xl group-hover:opacity-[0.08] transition-opacity duration-500"></div>

            <div class="relative z-10 mb-4 flex items-start justify-between gap-4">
              <h3 class="text-xl font-extrabold text-[color:var(--brand-gray)] tracking-tight leading-tight">{org.titulo}</h3>
              <Badge label={org.categoria} />
            </div>
            
            <p class="relative z-10 text-[14px] text-[color:var(--text-soft)] leading-relaxed flex-1">
              {org.descripcion}
            </p>
            
            <div class="relative z-10 mt-8 grid grid-cols-2 gap-3">
              <a
                href={`/docs/${org.fileName}`}
                target="_blank"
                class="flex items-center justify-center gap-2 rounded-xl bg-white border border-[color:var(--stroke)] p-3 text-sm font-bold text-[color:var(--brand-gray)] transition-all hover:border-[color:var(--brand-green)] hover:text-[color:var(--brand-green)] hover:shadow-sm"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                Visualizar
              </a>
              <a
                href={`/docs/${org.fileName}`}
                download
                class="flex items-center justify-center gap-2 rounded-xl bg-[color:var(--bg-soft)] border border-[color:var(--stroke)] p-3 text-sm font-bold text-[color:var(--brand-gray)] transition-all hover:bg-[color:var(--brand-green)] hover:text-white hover:border-[color:var(--brand-green)] hover:shadow-md"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Descargar
              </a>
            </div>
          </Card>
        ))}
      </div>
    </Container>
  </section>
</MainLayout>
