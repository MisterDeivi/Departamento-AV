---
import MainLayout from '@/layouts/MainLayout.astro';
import Container from '@/components/ui/Container.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import GuideCard from '@/components/data-display/GuideCard.astro';
import { guias } from '@/data/guias';
---

<MainLayout title="Guías | AV Guárico 1" description="Guías de audio y video para instalación y operación técnica.">
  <section class="py-12 sm:py-20">
    <Container>
      <SectionHeader
        eyebrow="Recursos Útiles"
        title="Guías de Operación"
        description="Estandarización de procesos para el montaje y ejecución de sistemas de audio y video en el circuito."
      />
      <div class="grid gap-6 md:grid-cols-2 mt-8">
        {guias.map((guia) => <GuideCard guia={guia} />)}
      </div>
    </Container>
  </section>
</MainLayout>
