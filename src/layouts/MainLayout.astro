---
import '@/styles/global.css';
import Container from '@/components/ui/Container.astro';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Plataforma operativa audiovisual conectada en tiempo real.' } = Astro.props;

const nav = [
  { href: '/', label: 'Inicio' },
  { href: '/grupos', label: 'Grupos' },
  { href: '/organigramas', label: 'Organigramas' },
  { href: '/eventos', label: 'Eventos' },
  { href: '/guias', label: 'Guías' },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#f8f9fc" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <ClientRouter />
  </head>
  <body class="antialiased font-sans">
    <header class="sticky top-0 z-50 border-b border-[color:var(--stroke)] bg-white/80 backdrop-blur-xl transition-all duration-300">
      <Container className="flex items-center justify-between gap-4 py-2">
        <a href="/" class="flex items-center gap-2 transition hover:opacity-80">
          <img src="/av.jpeg" alt="Logo AV Guárico 1" class="h-10 w-auto rounded-lg" />
          <span class="sr-only">AV GUÁRICO 1</span>
        </a>
        <nav class="flex flex-wrap justify-end gap-1 sm:gap-2">
          {nav.map((item) => {
            const active = currentPath === item.href;
            return (
              <a
                href={item.href}
                data-astro-prefetch="hover"
                class={`rounded-xl px-3 sm:px-4 py-2 text-[13px] sm:text-sm font-semibold transition-all duration-200 ${
                  active
                    ? 'bg-[color:var(--brand-green)]/15 text-[color:var(--brand-green)] shadow-sm'
                    : 'text-[color:var(--text-soft)] hover:bg-[color:var(--brand-green)]/5 hover:text-[color:var(--brand-green)]'
                }`}
              >
                {item.label}
              </a>
            );
          })}
        </nav>
      </Container>
    </header>

    <main class="pb-16 pt-4 sm:pt-8 min-h-[80vh] flex flex-col">
      <slot />
    </main>

    <footer class="border-t border-[color:var(--stroke)] bg-white/40 py-10">
      <Container className="flex flex-col items-center justify-between gap-6 sm:flex-row">
        <div class="flex items-center gap-3">
          <img src="/av.jpeg" alt="Logo AV Guárico 1" class="h-8 w-auto rounded opacity-80" />
          <span class="text-sm font-bold tracking-tight text-[color:var(--brand-gray)]">AV GUÁRICO 1</span>
        </div>
        <div class="text-center text-sm font-medium text-[color:var(--text-soft)] sm:text-right">
          <p>Departamento de Audio y Video · Circuito Guárico 1</p>
          <p class="mt-1 text-[color:var(--brand-green)] font-bold opacity-80">Plataforma Operativa Profesional</p>
        </div>
      </Container>
    </footer>
  </body>
</html>
